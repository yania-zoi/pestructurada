#include <stdio.h>
#include <stdlib.h>
void capturar(int m[3][3]){
    int i,j;
    for(i =0;i<3;i++){
        for(j=0;j<3;j++){
            scanf("%d ", &m[i][j]);
        }
    }
}
void mostrar(int m[3][3]){
    for(int i =0;i<3;i++){
        for(int j=0;j<3;j++){
            printf("%d ", m[i][j]);
        }
    printf("\n");
    }
}

int sumardiagonal(int m[3][3]){
    int valores[3], suma=0;
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            if(i==j){
                suma = suma+m[i][j];
            }
        }
    }
return suma;
}
void archivarenarchivo(int m[3][3]){
    FILE *f;
    f=fopen("tablero.txt","w");
    for(int i =0;i<3;i++){
        for(int j=0;j<3;j++){
            fprintf(f,"%d ", m[i][j]);
        }
    fprintf(f, "\n");
    }
    fclose(f);
}
int main(){
    int arr[3][3];
    capturar(arr);
    mostrar(arr);
    printf("suma diagonal %d", sumardiagonal(arr));
    archivarenarchivo(arr);
return 0;
}
